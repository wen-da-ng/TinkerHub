import os

# Step 1: Read the manifest file from the exact path
manifest_path = r"C:\Users\L\AppData\Local\Temp\tmp8kvpip3y\document_manifest.json"

try:
    with open(manifest_path, 'r') as f:
        data = json.load(f)
except FileNotFoundError:
    print(f"Error: Manifest file not found at {manifest_path}")
    exit()
except json.JSONDecodeError:
    print(f"Error: Invalid JSON format in manifest file")
    exit()

# Step 2: Define functions to process different document types
def process_spray_decision_file(path):
    spray_count = 0
    try:
        with open(path, 'r') as f:
            lines = f.readlines()
            for line in lines:
                if 'Action: Spray' in line:
                    spray_count += 1
        print(f"Spray action count from {os.path.basename(path)}: {spray_count}")
        return spray_count
    except FileNotFoundError:
        print(f"Error: Spray decision file not found at {path}")
        return 0
    except Exception as e:
        print(f"Error processing spray decision file: {str(e)}")
        return 0

def process_sales_data_file(path):
    total_revenue = 0.0
    try:
        with open(path, 'r') as f:
            lines = f.readlines()
            for line in lines:
                parts = line.split()
                for part in parts:
                    if "TotalPrice:" in part:
                        # Extract the value after TotalPrice:
                        value_str = part.split(":")[1]
                        try:
                            total = float(value_str)
                            total_revenue += total
                        except ValueError:
                            pass
        print(f"Total revenue from {os.path.basename(path)}: ${total_revenue:.2f}")
        return total_revenue
    except FileNotFoundError:
        print(f"Error: Sales data file not found at {path}")
        return 0.0
    except Exception as e:
        print(f"Error processing sales data file: {str(e)}")
        return 0.0

# Step 3: Process each document based on its type
sales_total = 0.0
spray_count_total = 0

for doc in data.get('documents', []):
    try:
        if 'original_name' not in doc or 'path' not in doc:
            continue
            
        original_name = doc['original_name']
        file_path = doc['path']
        
        if "spray_decision" in original_name.lower():
            spray_count = process_spray_decision_file(file_path)
            spray_count_total += spray_count
        elif "sales_data" in original_name.lower():
            revenue = process_sales_data_file(file_path)
            sales_total += revenue
        else:
            print(f"Skipping unknown file type: {original_name}")
    except Exception as e:
        print(f"Error processing document: {str(e)}")
        continue

# Step 4: Print final results
print("\nFinal Results:")
print(f"Total spray actions across all files: {spray_count_total}")
print(f"Total revenue across all sales files: ${sales_total:.2f}")
