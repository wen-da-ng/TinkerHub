import json

def main():
    # Hardcoded file paths as specified
    manifest_path = "C:\\Users\\L\\AppData\\Local\\Temp\\tmp1u5yagtn\\document_manifest.json"
    
    try:
        # Load manifest file
        with open(manifest_path, 'r') as f:
            manifest_data = json.load(f)
        
        # Extract documents and base directory from manifest
        documents = manifest_data.get('documents', [])
        base_directory = manifest_data.get('base_directory', "")
        
        total_spray_count = 0
        
        # Process each document
        for doc in documents:
            doc_path = doc.get('path', '')
            
            try:
                with open(doc_path, 'r') as f:
                    lines = f.readlines()
                
                # Count spray actions
                spray_count = sum(1 for line in lines if line.strip() == "Action: Spray")
                total_spray_count += spray_count
                
            except FileNotFoundError:
                print(f"Document not found: {doc_path}")
            except IOError as e:
                print(f"Error reading document {doc_path}: {str(e)}")
        
        # Output results
        print(f"\nAnalysis Complete!")
        print(f"Total Spray Actions Executed: {total_spray_count}")
        
    except FileNotFoundError:
        print("Manifest file not found at specified path.")
    except json.JSONDecodeError as e:
        print(f"Error decoding JSON manifest: {str(e)}")
    except IOError as e:
        print(f"Error reading manifest file: {str(e)}")

if __name__ == "__main__":
    main()
