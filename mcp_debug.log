2025-03-31 22:58:48,374 - __main__ - INFO - import os

def process_documents(directory):
    count_spray = 0
    total_revenue = 0.0

    # Iterate over all files in the directory
    for filename in os.listdir(directory):
        file_path = os.path.join(directory, filename)
        if not os.path.isfile(file_path):
            continue  # Skip directories

        with open(file_path, 'r', encoding='utf-8') as f:
            lines = f.readlines()
        
        is_spray = False
        quantity = None
        unit_price = None

        for line in lines:
            line = line.strip()
            if not line:
                continue
            
            parts = line.split(':')
            if len(parts) != 2:
                continue

            key, value = parts[0].strip(), parts[1].strip()

            if key.lower() == 'action':
                is_spray = True
            elif key.lower() == 'quantity':
                quantity = float(value)
            elif key.lower() == 'unitprice':
                unit_price = float(value)

        if is_spray:
            count_spray += 1
        else:
            if quantity is not None and unit_price is not None:
                total_revenue += quantity * unit_price

    return count_spray, total_revenue

# Example usage:
directory = 'path_to_your_directory'  # Replace with the actual directory path
spray_count, revenue = process_documents(directory)
print(f"Total spray actions: {spray_count}")
print(f"Total revenue: {revenue:.2f}")
