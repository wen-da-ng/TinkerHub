import json
import os

def load_json_file(filepath):
    try:
        with open(filepath, 'r') as file:
            data = json.load(file)
        return data
    except FileNotFoundError:
        print(f"Error: File not found at path '{filepath}'")
        return None
    except json.JSONDecodeError as e:
        print(f"Error decoding JSON from file '{filepath}': {str(e)}")
        return None

def count_spray_actions(filepath):
    spray_count = 0
    try:
        with open(filepath, 'r') as f:
            lines = f.readlines()
        for line in lines:
            if "Action: Spray" in line:
                spray_count +=1
        return spray_count
    except Exception as e:
        print(f"Error reading file '{filepath}': {str(e)}")
        return 0

def main():
    manifest_path = "C:\\Users\\L\\AppData\\Local\\Temp\\tmpe6_3r1a3\\document_manifest.json"
    
    try:
        manifest_data = load_json_file(manifest_path)
        if not manifest_data:
            return
        
        total_sprays = 0
        documents = manifest_data.get("documents", [])
        
        for doc in documents:
            original_name = doc.get("original_name", "")
            if "spray_decision.csv" in original_name:  # Check if this is a spray decision file
                file_path = doc.get("path", "")
                if not file_path:
                    continue
                
                sprays = count_spray_actions(file_path)
                total_sprays += sprays
        
        print(f"\nTotal spray actions executed across all documents: {total_sprays}")

    except Exception as e:
        print(f"An error occurred while processing the manifest: {str(e)}")

if __name__ == "__main__":
    main()
