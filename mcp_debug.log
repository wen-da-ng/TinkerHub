import os
from collections import defaultdict, Counter

def load_json_file(file_path):
    try:
        with open(file_path, 'r', encoding='utf-8') as f:
            return json.load(f)
    except Exception as e:
        print(f"Error loading JSON file: {e}")
        return None

def process_manifest_data(manifest_data, base_dir=""):
    spray_counts = 0
    documents = manifest_data.get("documents", [])
    
    for doc in documents:
        # Get the exact path from the document's 'path' field
        file_path = doc["path"]
        
        try:
            with open(file_path, 'r', encoding='utf-8') as f:
                content = f.read()
                
            # Count "Action: Spray" occurrences
            spray_count = content.count("Action: Spray")
            spray_counts += spray_count
            
        except Exception as e:
            print(f"Error processing file {file_path}: {e}")
            continue
        
    return spray_counts

def main():
    manifest_file_path = r"C:\Users\L\AppData\Local\Temp\tmpx7v_7xjn\document_manifest.json"
    
    # Load the manifest
    manifest_data = load_json_file(manifest_file_path)
    if not manifest_data:
        print("Failed to load manifest file")
        return
    
    # Process each document
    total_spray_actions = process_manifest_data(manifest_data)
    
    # Output results
    print(f"\nTotal spray actions executed: {total_spray_actions}")

if __name__ == "__main__":
    main()
