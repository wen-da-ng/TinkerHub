2025-03-31 22:55:45,377 - __main__ - INFO - import sys

def main():
    lines = [line.strip() for line in sys.stdin]
    spray_lines = []
    sales_lines = []

    current_document = None  # Can be 'spray' or 'sales', None otherwise
    for line in lines:
        if line.startswith('Document:'):
            doc_id = line.split(': ')[1]
            if doc_id == 'spray_data':
                current_document = 'spray'
                spray_lines = []
            elif doc_id == 'sales_data':
                current_document = 'sales'
                sales_lines = []
            else:
                current_document = None
        else:
            if current_document is not None:
                if current_document == 'spray':
                    spray_lines.append(line)
                elif current_document == 'sales':
                    sales_lines.append(line)

    # Process spray data
    count_sprays = 0
    for line in spray_lines:
        parts = line.split(': ')
        if parts[0] == 'Action' and len(parts) > 1:
            action = parts[1]
            if action == 'Spray':
                count_sprays += 1

    # Process sales data
    total_revenue = 0.0
    current_sale = {}
    for line in sales_lines:
        if line.startswith('Quantity:'):
            quantity = float(line.split(': ')[1])
            current_sale['quantity'] = quantity
        elif line.startswith('UnitPrice:'):
            if 'quantity' in current_sale:
                unit_price = float(line.split(': ')[1])
                total_revenue += current_sale['quantity'] * unit_price
                current_sale.clear()

    print(f"Number of sprays: {count_sprays}")
    print(f"Total revenue: {total_revenue}")

if __name__ == "__main__":
    main()
