import json

# Hardcoded manifest file path as specified
MANIFEST_PATH = "C:\\Users\\L\\AppData\\Local\\Temp\\tmphp5sn5va\\document_manifest.json"

def main():
    # Load the manifest file
    try:
        with open(MANIFEST_PATH, 'r') as f:
            manifest = json.load(f)
    except FileNotFoundError:
        print(f"Manifest file not found at: {MANIFEST_PATH}")
        return
    except json.JSONDecodeError:
        print("Could not parse JSON in the manifest file")
        return

    # Initialize spray count
    spray_count = 0

    # Process each document in the manifest
    for doc in manifest.get('documents', []):
        doc_path = doc.get('path')
        if not doc_path:
            print(f"Document path missing for document ID: {doc.get('id')}")
            continue

        try:
            with open(doc_path, 'r') as f:
                lines = f.readlines()
                for line in lines:
                    # Split each line into key and value
                    parts = [p.strip() for p in line.split(':')]
                    if len(parts) != 2:
                        continue  # Skip invalid lines

                    key, value = parts[0], parts[1]
                    if key == 'Action' and value == 'Spray':
                        spray_count += 1
        except FileNotFoundError:
            print(f"Document file not found at: {doc_path}")
            continue
        except Exception as e:
            print(f"Error reading document {doc.get('id')}: {str(e)}")
            continue

    # Output the result
    print(f"The spray action was executed {spray_count} times.")

if __name__ == "__main__":
    main()
